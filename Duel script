-- Main GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "Primoo_Tp_Ragdoll"
screenGui.ResetOnSpawn = false
screenGui.Parent = Player:WaitForChild("PlayerGui")

-- Background with dark blue
local background = Instance.new("Frame")
background.Size = UDim2.new(1, 0, 1, 0)
background.BackgroundColor3 = Color3.fromRGB(10, 20, 40) -- Dark blue
background.BackgroundTransparency = 0.3
background.Parent = screenGui

-- Particles
local particles = {}
for i = 1, 20 do
	local particle = Instance.new("Frame")
	particle.Size = UDim2.new(0, math.random(2, 5), 0, math.random(2, 5))
	particle.Position = UDim2.new(math.random(), 0, math.random(), 0)
	particle.BackgroundColor3 = Color3.fromRGB(100, 150, 255) -- Light blue
	particle.BackgroundTransparency = 0.3
	particle.BorderSize = 0
	particle.Parent = background
	
	-- Store particle data
	table.insert(particles, {
		frame = particle,
		speed = math.random(10, 50) / 100,
		direction = Vector2.new(math.random(-100, 100)/1000, math.random(-100, 100)/1000)
	})
end

-- Particle animation
RunService.Heartbeat:Connect(function(dt)
	for _, p in ipairs(particles) do
		local pos = p.frame.Position
		local newX = pos.X.Scale + p.direction.X * dt * 2
		local newY = pos.Y.Scale + p.direction.Y * dt * 2
		
		-- Wrap around screen
		if newX > 1 then newX = 0 end
		if newX < 0 then newX = 1 end
		if newY > 1 then newY = 0 end
		if newY < 0 then newY = 1 end
		
		p.frame.Position = UDim2.new(newX, 0, newY, 0)
	end
end)

